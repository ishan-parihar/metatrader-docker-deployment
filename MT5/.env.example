# MT5 Docker Configuration
# Copy this file to .env and fill in your broker credentials

# Broker credentials (leave empty for offline mode)
MT5_BROKER_LOGIN=
MT5_BROKER_PASSWORD=
MT5_BROKER_SERVER=MetaQuotes-Demo

# noVNC (browser-based VNC client)
MT5_ENABLE_NOVNC=1
MT5_NOVNC_PORT=6080

# VNC (optional, for native VNC clients like RealVNC, TigerVNC)
MT5_ENABLE_VNC=0
MT5_VNC_PORT=5900

# Timezone
TZ=UTC
