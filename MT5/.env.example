# MT5 Docker Configuration
# Copy this file to .env and fill in your broker credentials

# Broker credentials (leave empty for offline mode)
MT5_BROKER_LOGIN=
MT5_BROKER_PASSWORD=
MT5_BROKER_SERVER=MetaQuotes-Demo

# noVNC (browser-based VNC client)
MT5_ENABLE_NOVNC=1
MT5_NOVNC_PORT=6080

# VNC (optional, for native VNC clients like RealVNC, TigerVNC)
MT5_ENABLE_VNC=0
MT5_VNC_PORT=5900

# Timezone
TZ=UTC

# Production knobs
MT5_MAX_BARS=5000        # chart-bars RAM cap
MT5_MEM_LIMIT=1400m      # container memory limit (800m on a 1GB host)
MT5_BIND=0.0.0.0         # 127.0.0.1 = local-only noVNC/VNC (use tunnel/auth)
