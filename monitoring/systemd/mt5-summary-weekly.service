[Unit]
Description=MT5 Monitoring Weekly Summary

[Service]
Type=oneshot
User=%USER
WorkingDirectory=%HOME/mt5-monitoring
ExecStart=/usr/bin/python3 %HOME/mt5-monitoring/bin/mt5_summary.py weekly --send
StandardOutput=append:%HOME/mt5-monitoring/state/logcheck.log
StandardError=append:%HOME/mt5-monitoring/state/logcheck.log
