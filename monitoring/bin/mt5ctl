#!/usr/bin/env bash
# mt5ctl — AD-12 MT5 control utility for on-demand checks.
#
# Commands:
#   snapshot    — comprehensive account snapshot (positions + history + rolling)
#   status      — quick health (1-line)
#   health      — full health check (logcheck)
#   charts      — chart attach status
#   alert       — send test alert
#   help        — show this help
#
# Usage:
#   mt5ctl snapshot          # everything in one shot
#   mt5ctl snapshot -json    # raw JSON output
#   mt5ctl status
#   mt5ctl health
#   mt5ctl charts

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOGCHECK="${SCRIPT_DIR}/mt5_logcheck.sh"
ALERT="${SCRIPT_DIR}/mt5_alert.py"
REPORT_DIR="/home/ishanp/mt5-deploy/logcheck/reports"

SNAPSHOT_PATH="/config/.wine/drive_c/users/root/AppData/Roaming/MetaQuotes/Terminal/Common/Files/account_snapshot.json"

cmd="${1:-help}"
shift || true

# Helper: read snapshot from docker
_read_snapshot() {
    docker exec mt5-terminal cat "$SNAPSHOT_PATH" 2>/dev/null | python3 -c "
import json, sys
raw = sys.stdin.buffer.read()
if raw[:2] == b'\xff\xfe':
    text = raw[2:].decode('utf-16-le', errors='replace')
elif raw[:2] == b'\xfe\xff':
    text = raw[2:].decode('utf-16-be', errors='replace')
elif raw[:3] == b'\xef\xbb\xbf':
    text = raw[3:].decode('utf-8', errors='replace')
else:
    text = raw.decode('utf-8', errors='replace')
try:
    print(json.dumps(json.loads(text), indent=2))
except Exception as e:
    print(f'ERROR: Cannot parse snapshot: {e}', file=sys.stderr)
    sys.exit(1)
"
}

case "$cmd" in
    snapshot)
        fmt="${1:-text}"
        if [[ "$fmt" == "-json" || "$fmt" == "json" ]]; then
            _read_snapshot
            exit 0
        fi

        _read_snapshot | python3 -c "
import json, sys
s = json.load(sys.stdin)

# ── Account header ──
login = s.get('login', '?')
server = s.get('server', '?')
balance = s.get('balance', 0)
equity = s.get('equity', 0)
currency = s.get('currency', '')
profit = s.get('profit', 0)
margin = s.get('margin', 0)
free_margin = s.get('free_margin', 0)
margin_level = s.get('margin_level', 0)
leverage = s.get('leverage', 0)
ts = s.get('ts', '?')

net_sign = '+' if profit >= 0 else ''
print(f'💰 Account: {login} @ {server}')
print(f'   Balance:    {balance:.2f} {currency}')
print(f'   Equity:     {equity:.2f}')
print(f'   Open PnL:   {net_sign}{profit:.2f}')
print(f'   Margin:     {margin:.2f} (free: {free_margin:.2f})')
print(f'   Mgn Level:  {margin_level:.1f}% | Leverage: 1:{leverage}')
print(f'   Updated:    {ts}')

# ── Open positions ──
positions = s.get('positions', [])
pos_summary = s.get('position_summary', {})
print()
if not positions:
    print('📊 Open Positions: 0')
else:
    total_pnl = pos_summary.get('total_pnl', 0)
    total_swap = pos_summary.get('total_swap', 0)
    total_comm = pos_summary.get('total_commission', 0)
    total_net = pos_summary.get('total_net', 0)
    net_s = '+' if total_net >= 0 else ''
    print(f'📊 Open Positions ({len(positions)}) — Net: {net_s}{total_net:.2f}')
    print()
    for p in positions:
        pnl = p['profit']
        swap = p.get('swap', 0)
        comm = p.get('commission', 0)
        net = pnl + swap + comm
        sign = '+' if pnl >= 0 else ''
        net_s = '+' if net >= 0 else ''
        pnl_pct = p.get('pnl_pct', 0)
        sl = p.get('sl', 0)
        tp = p.get('tp', 0)
        sl_s = f'SL={sl:.5f}' if sl > 0 else 'SL=—'
        tp_s = f'TP={tp:.5f}' if tp > 0 else 'TP=—'
        print(f'  #{p[\"ticket\"]} {p[\"type\"]} {p[\"symbol\"]} {p[\"lots\"]} lots')
        print(f'    {p[\"open_price\"]:.5f} → {p[\"current_price\"]:.5f} | PnL: {sign}{pnl:.2f} | Net: {net_s}{net:.2f} ({pnl_pct:+.2f}%)')
        print(f'    {sl_s} {tp_s} | Swap: {swap:.2f} | Comm: {comm:.2f} | Magic: {p[\"magic\"]}')
    print()
    print(f'  ── Total: PnL {total_pnl:+.2f} | Swap {total_swap:+.2f} | Comm {total_comm:+.2f} | Net {net_s}{total_net:.2f}')

# ── History summary ──
hist = s.get('history_summary', {})
print()
count = hist.get('count', 0)
wins = hist.get('wins', 0)
losses = hist.get('losses', 0)
wr = hist.get('win_rate', 0)
hp = hist.get('total_pnl', 0)
hs = hist.get('total_swap', 0)
hc = hist.get('total_commission', 0)
hn = hist.get('total_net', 0)
hn_s = '+' if hn >= 0 else ''
print(f'📋 History: {count} trades ({wins}W/{losses}L, {wr:.0f}% WR)')
print(f'   PnL: {hp:+.2f} | Swap: {hs:+.2f} | Comm: {hc:+.2f} | Net: {hn_s}{hn:.2f}')

# ── Recent history deals (last 10) ──
history = s.get('history', [])
if history:
    print()
    print(f'  Last {min(10, len(history))} closed trades:')
    for t in history[:10]:
        net = t.get('net', t.get('profit', 0))
        sign = '+' if t.get('profit', 0) >= 0 else ''
        net_s = '+' if net >= 0 else ''
        print(f'    #{t.get(\"ticket\",\"?\")} {t.get(\"symbol\",\"?\")} {t.get(\"lots\",0)} lots')
        print(f'      {t.get(\"open_price\",0):.5f} → {t.get(\"close_price\",0):.5f} | Net: {net_s}{net:.2f} | Magic: {t.get(\"magic\",\"?\")}')

# ── Rolling stats ──
rolling = s.get('rolling', {})
if rolling:
    print()
    print('📈 Rolling PnL:')
    for period, label in [('daily', 'Today'), ('weekly', 'Week'), ('monthly', 'Month')]:
        r = rolling.get(period, {})
        pnl = r.get('pnl', 0)
        trades = r.get('trades', 0)
        w = r.get('wins', 0)
        l = r.get('losses', 0)
        wr = r.get('win_rate', 0)
        sign = '+' if pnl >= 0 else ''
        print(f'  {label:8s}: {sign}{pnl:+.2f} | {trades} trades ({w}W/{l}L, {wr:.0f}% WR)')
"
        ;;

    status)
        latest="${REPORT_DIR}/latest.json"
        if [[ -f "$latest" ]]; then
            python3 -c "
import json, sys
with open('$latest') as f:
    r = json.load(f)
sev = r.get('severity', '?')
icon = {'OK':'✅', 'WARNING':'⚠️', 'CRITICAL':'🔴'}.get(sev, '?')
ts = r.get('timestamp', '?')[:16]
ch = r.get('charts', {})
loaded = ch.get('loaded_count', ch.get('found_count', '?'))
expected = ch.get('expected_count', '?')
print(f'{icon} {sev} | charts {loaded}/{expected} | last check {ts}')
"
        else
            echo "⚠️  No report yet — run: mt5ctl health"
        fi
        ;;

    health)
        "${LOGCHECK}" --days "${1:-1}"
        ;;

    charts)
        echo "── Chart attach status ──"
        "${LOGCHECK}" --days 2 --json 2>/dev/null | python3 -c "
import json, sys
r = json.load(sys.stdin)
ch = r.get('charts', {})
loaded = ch.get('loaded_count', ch.get('found_count', '?'))
expected = ch.get('expected_count', '?')
print(f'Loaded: {loaded}/{expected}')
if ch.get('missing_magics'):
    print(f'🔴 Missing: {ch[\"missing_magics\"]}')
if ch.get('wrong_build_magics'):
    print(f'🔴 Wrong build: {ch[\"wrong_build_magics\"]}')
print()
for mg, info in sorted(ch.get('charts', {}).items()):
    warmup = info.get('warmup_bars')
    warmup_str = f'warmup={warmup}' if warmup else '⚠️ NO warmup'
    trees = info.get('trees')
    trees_ok = '✅' if trees == 141 else ('🔴' if trees else '⚠️')
    trees_str = f'{trees} trees' if trees else 'no banner'
    print(f'  {trees_ok} magic={mg} {info.get(\"symbol\",\"?\")},{info.get(\"tf\",\"?\")} {info.get(\"atom\",\"?\")} ({trees_str}, {warmup_str})')
aux = ch.get('auxiliary_eas', {})
if aux:
    print()
    print(f'Auxiliary EAs ({len(aux)}):')
    for name, ainfo in sorted(aux.items()):
        icon = '✅' if ainfo.get('state') == 'loaded' else '🔴'
        print(f'  {icon} {name} ({ainfo.get(\"symbol\",\"?\")},{ainfo.get(\"tf\",\"?\")}) state={ainfo.get(\"state\",\"?\")}')
"
        ;;

    alert)
        subcmd="${1:-test}"
        case "$subcmd" in
            test)
                echo "Sending test alert..."
                python3 "${ALERT}" \
                    --severity WARNING \
                    --subject "[AD-12] Test alert from mt5ctl" \
                    --body "This is a test alert from mt5ctl at $(date -Iseconds). If you received this, both email and Telegram channels are working."
                ;;
            *)
                echo "Usage: mt5ctl alert test"
                exit 1
                ;;
        esac
        ;;

    help|--help|-h|"")
        cat <<EOF
mt5ctl — AD-12 MT5 control utility

Usage: mt5ctl <command> [args]

Commands:
  snapshot              Comprehensive account snapshot (positions + history + rolling)
  snapshot -json        Raw JSON output
  status                Quick health (1-line)
  health [days]         Full health check (default: 1 day)
  charts                Chart attach status
  alert test            Send a test alert

Examples:
  mt5ctl snapshot
  mt5ctl snapshot -json
  mt5ctl status
  mt5ctl health 3
  mt5ctl charts

Reports: $REPORT_DIR
EOF
        ;;

    *)
        echo "Unknown command: $cmd"
        echo "Run 'mt5ctl help' for usage."
        exit 1
        ;;
esac
